    },
    {
      "cell_type": "code",
      "source": [
        "# Entrenamiento adversarial: el generador y el discriminador compiten\n",
        "criterio = nn.BCELoss()  # mide el error en la clasificacion real/falso\n",
        "opt_g = torch.optim.Adam(generador.parameters(), lr=0.0002, betas=(0.5, 0.999))\n",
        "opt_d = torch.optim.Adam(discriminador.parameters(), lr=0.0002, betas=(0.5, 0.999))\n",
        "\n",
        "epochs = 50\n",
        "for epoch in range(epochs):\n",
        "    for imgs_reales, _ in loader:\n",
        "        imgs_reales = imgs_reales.to(device)\n",
        "        n = imgs_reales.size(0)\n",
        "\n",
        "        # Etiquetas: 1 para reales, 0 para falsas\n",
        "        reales = torch.ones(n, 1).to(device)\n",
        "        falsas = torch.zeros(n, 1).to(device)\n",
        "\n",
        "        # --- Entrenar el DISCRIMINADOR ---\n",
        "        # Aprende a reconocer reales como 1 y generadas como 0\n",
        "        ruido = torch.randn(n, dim_ruido).to(device)\n",
        "        imgs_falsas = generador(ruido)\n",
        "        perdida_d = criterio(discriminador(imgs_reales), reales) + \\\n",
        "                    criterio(discriminador(imgs_falsas.detach()), falsas)\n",
        "        opt_d.zero_grad()\n",
        "        perdida_d.backward()\n",
        "        opt_d.step()\n",
        "\n",
        "        # --- Entrenar el GENERADOR ---\n",
        "        # Aprende a que sus imagenes enganen al discriminador (que diga 1)\n",
        "        ruido = torch.randn(n, dim_ruido).to(device)\n",
        "        imgs_falsas = generador(ruido)\n",
        "        perdida_g = criterio(discriminador(imgs_falsas), reales)\n",
        "        opt_g.zero_grad()\n",
        "        perdida_g.backward()\n",
        "        opt_g.step()\n",
        "\n",
        "    print(f\"Epoch {epoch+1}/{epochs} | Perdida D: {perdida_d.item():.3f} | Perdida G: {perdida_g.item():.3f}\")\n",
        "\n",
        "print(\"Entrenamiento terminado\")"
      ],
