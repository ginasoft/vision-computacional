      "source": [
        "# Actividad GAN - Vision Computacional UP\n",
        "# DCGAN entrenada desde cero para generar imagenes artificiales (digitos MNIST)\n",
        "\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torchvision\n",
        "import torchvision.transforms as transforms\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "print(\"Usando:\", device)\n",
        "\n",
        "# Cargamos el dataset MNIST (digitos escritos a mano)\n",
        "transform = transforms.Compose([\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize([0.5], [0.5])  # normaliza a rango [-1, 1]\n",
        "])\n",
        "dataset = torchvision.datasets.MNIST(root=\"./data\", train=True, download=True, transform=transform)\n",
        "loader = torch.utils.data.DataLoader(dataset, batch_size=128, shuffle=True)\n",
        "\n",
        "print(\"Dataset cargado:\", len(dataset), \"imagenes\")"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Las dos redes que compiten (entrenamiento adversarial)\n",
        "dim_ruido = 100  # tamaño del vector de ruido (la \"semilla\")\n",
        "\n",
        "# GENERADOR: toma un vector de ruido y lo transforma en una imagen\n",
        "class Generador(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.red = nn.Sequential(\n",
        "            nn.Linear(dim_ruido, 256), nn.ReLU(),\n",
        "            nn.Linear(256, 512), nn.ReLU(),\n",
        "            nn.Linear(512, 1024), nn.ReLU(),\n",
        "            nn.Linear(1024, 28*28), nn.Tanh()  # salida: imagen 28x28\n",
        "        )\n",
        "    def forward(self, x):\n",
        "        return self.red(x).view(-1, 1, 28, 28)\n",
        "\n",
        "# DISCRIMINADOR: recibe una imagen y decide si es real (1) o falsa (0)\n",
        "class Discriminador(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.red = nn.Sequential(\n",
        "            nn.Linear(28*28, 512), nn.LeakyReLU(0.2),\n",
        "            nn.Linear(512, 256), nn.LeakyReLU(0.2),\n",
        "            nn.Linear(256, 1), nn.Sigmoid()  # salida: probabilidad real/falso\n",
        "        )\n",
        "    def forward(self, x):\n",
        "        return self.red(x.view(-1, 28*28))\n",
        "\n",
        "generador = Generador().to(device)\n",
        "discriminador = Discriminador().to(device)\n",
        "\n",
        "print(\"Generador y Discriminador creados\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "GTuGn-XS1GIc",
