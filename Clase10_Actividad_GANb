        "# Generamos imagenes nuevas con el generador ya entrenado\n",
        "generador.eval()\n",
        "\n",
        "# Creamos 16 vectores de ruido nuevos (16 semillas distintas)\n",
        "ruido = torch.randn(16, dim_ruido).to(device)\n",
        "with torch.no_grad():\n",
        "    imgs_generadas = generador(ruido).cpu()\n",
        "\n",
        "# Mostramos las 16 imagenes generadas en una grilla 4x4\n",
        "fig, axs = plt.subplots(4, 4, figsize=(8, 8))\n",
        "for i, ax in enumerate(axs.flat):\n",
        "    ax.imshow(imgs_generadas[i][0], cmap=\"gray\")\n",
